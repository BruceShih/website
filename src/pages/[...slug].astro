---
import { useStoryblokApi } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import DefaultLayout from '../layouts/DefaultLayout.astro';

export async function getStaticPaths() {
  const api = useStoryblokApi();
  const { data: pages } = await api.get('cdn/stories', {
    version: import.meta.env.DEV ? 'draft' : 'published'
  });

  return pages.stories.map((page: any) => {
    console.log(page.full_slug);
    return {
      params: {
        slug: page.full_slug === 'index' ? undefined : page.full_slug
      },
      props: { content: page.content }
    };
  });
}

const { content } = Astro.props;
---

<DefaultLayout title={content.title}>
  <StoryblokComponent blok={content} />
</DefaultLayout>
